# Copy to `.env` and fill in real values locally.
# Never commit `.env` or any file containing secrets (API keys, service role keys, etc.).

# --- Frontend (Vite; only `VITE_*` vars are exposed to the browser) ---
# Base URL for API calls when not using the dev proxy. With Vite proxy (`/api` → backend),
# you can leave this empty and use relative paths like `/api/...` in `src/lib/api.ts`.
VITE_API_URL=

# --- Backend (Node server only; loaded by `server/` — not bundled into the client) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=
OLLAMA_EMBEDDING_MODEL=
EMBEDDING_DIM=
CHUNK_SIZE=
CHUNK_OVERLAP=
